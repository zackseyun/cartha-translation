__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env
.env.local

.vscode/
.idea/
.DS_Store

# LLM output caches (regenerable from source + prompt)
.cache/
drafts/raw/
state/

# Per-page transcription backups from apply_transcription_reviews.py.
# Restorable by `mv <f>.bak <f>`; not committed to avoid ~2x storage bloat.
sources/lxx/swete/transcribed/*.txt.bak

# Claude Opus review artifacts from the superseded Opus cross-read run.
# The parseable subset was folded into the Azure pass; the rest were
# limit/stop messages and are not worth tracking.
sources/lxx/swete/transcribed/*.opus-review.json

# Reviewer private keys must never be committed
*.key
*_private.pem

# Local tool configuration
.tool_config.local.json
.DS_Store

# 2 Esdras source PDFs — tracked via sources/2esdras/MANIFEST.md with SHA-256 hashes
# (following the Swete precedent; rehydrate from archive.org if missing)
sources/2esdras/scans/*.pdf
sources/2esdras/latin/*.pdf

# 1 Enoch source PDFs — tracked via sources/enoch/MANIFEST.md
sources/enoch/scans/*.pdf
# Jubilees source PDFs — tracked via sources/jubilees/MANIFEST.md
sources/jubilees/scans/*.pdf

# Group A Greek extra-canonical source PDFs — tracked via per-text manifests
sources/didache/scans/*.pdf
sources/1_clement/scans/*.pdf
sources/shepherd_of_hermas/scans/*.pdf
sources/testaments_twelve_patriarchs/scans/*.pdf
